            type: list
        etc_ssh_config_content:
            description: >
                The contents of /etc/ssh/ssh_config file,
                or 'N/A' if C(gather_diagnostics_gather_ssh_config) is C(False) or file doesn't exist.
            type: list
        etc_sshd_config_content:
            description: >
                The contents of /etc/ssh/sshd_config file,
                or 'N/A' if C(gather_diagnostics_gather_ssh_config) is C(False) or file doesn't exist.
            type: list

gather_diagnostics_control_results:
    description: >
        A fact set on the control node containing all control node
        diagnostic data. This data is also written to a YAML file on the
        control node if C(gather_diagnostics_save_control_log) is C(True).
    returned: when C(gather_diagnostics_gather_control) is C(True)
    type: dict
    contains:
        ansible_version:
            description: The output of the `ansible --version` command.
            type: str
        ssh_version:
