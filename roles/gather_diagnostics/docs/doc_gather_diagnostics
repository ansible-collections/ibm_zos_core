            type: list
        locale:
            description: A list of locale settings from the control node.
            type: list
        collections:
            description: A list of installed Ansible collections from `ansible-galaxy collection list`.
            type: list
        environment:
            description: A list of environment variables from the control node.
            type: list
        control_facts:
            description: A dictionary of facts from the control node gathered via `ansible.builtin.setup`.
            type: dict
